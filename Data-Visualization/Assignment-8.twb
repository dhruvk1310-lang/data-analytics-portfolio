  <worksheets>
    <worksheet name='Sheet 1'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book'>SLA Breach Rate by System and Priority
</run>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'>SLA targets assumed: P1=8h, P2=16h, P3=24h, P4=48h</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='assignment8_IT_Operations' name='federated.0wtpy0c09h16nj1bglumr0h1h221' />
          </datasources>
          <datasource-dependencies datasource='federated.0wtpy0c09h16nj1bglumr0h1h221'>
            <column caption='Breach Rate' datatype='real' default-format='p0.00%' name='[Calculation_5646536164495360]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG(&#10;  IF [Resolve_Time_Hours] &gt; &#10;     (CASE [Priority] &#10;        WHEN &quot;P1&quot; THEN 8 &#10;        WHEN &quot;P2&quot; THEN 16 &#10;        WHEN &quot;P3&quot; THEN 24 &#10;        WHEN &quot;P4&quot; THEN 48 &#10;      END)&#10;  THEN 1.0 ELSE 0.0 END&#10;)' />
            </column>
            <column datatype='string' name='[Priority]' role='dimension' type='nominal' />
            <column caption='Resolve Time Hours' datatype='real' name='[Resolve_Time_Hours]' role='measure' type='quantitative' />
            <column datatype='string' name='[System]' role='dimension' type='nominal' />
            <column-instance column='[Priority]' derivation='None' name='[none:Priority:nk]' pivot='key' type='nominal' />
            <column-instance column='[System]' derivation='None' name='[none:System:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_5646536164495360]' derivation='User' name='[usr:Calculation_5646536164495360:qk]' pivot='key' type='quantitative' />
